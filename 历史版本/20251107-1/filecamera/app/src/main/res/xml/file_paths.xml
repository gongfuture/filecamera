<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 现有的外部存储Pictures目录 -->
    <external-files-path name="my_images" path="Pictures" />
    
    <!-- 新增：应用私有文件目录 /data/data/包名/files/ -->
    <files-path name="private_files" path="/" />
    
    <!-- 新增：应用私有缓存目录 /data/data/包名/cache/ -->
    <cache-path name="private_cache" path="/" />
    
    <!-- 新增：外部存储应用专用根目录 /Android/data/包名/files/ -->
    <external-files-path name="external_files" path="/" />
    
    <!-- 新增：外部存储应用专用缓存目录 /Android/data/包名/cache/ -->
    <external-cache-path name="external_cache" path="/" />
    <!-- 新增：外部存储根目录 /storage/emulated/0/ (需要存储权限) -->
    <external-path name="external_storage" path="/" />
</paths>